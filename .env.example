# Required
ORIGIN=https://diff.yourdomain.com
POSTGRES_PASSWORD=changeme

# Optional: PostgreSQL
POSTGRES_USER=newsdiff
POSTGRES_DB=newsdiff

# Optional: Port nginx listens on (put a TLS proxy in front of this)
LISTEN_PORT=8080

# Optional: ActivityPub bot identity
BOT_USERNAME=bot
BOT_NAME=NewsDiff Bot

# Optional: Bluesky syndication
# BLUESKY_HANDLE=yourhandle.bsky.social
# BLUESKY_PASSWORD=xxxx-xxxx-xxxx-xxxx
# BLUESKY_EMBED_TYPE=image

# Optional: Syndication rate limit (milliseconds, default: 5 minutes)
# SYNDICATE_RATE_MS=300000
